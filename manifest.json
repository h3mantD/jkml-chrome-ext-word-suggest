{
  "manifest_version": 3,
  "name": "JKLM BombParty Helper",
  "version": "0.1.0",
  "description": "Shows word suggestions for the current BombParty chunk.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://jklm.fun/*",
    "https://*.jklm.fun/*"
  ],
  "action": {
    "default_title": "BombParty Helper",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Show or hide suggestion panel"
    },
    "refresh-suggestions": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Force refresh current chunk and suggestions"
    },
    "panic-hide": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Hide suggestion panel instantly"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://jklm.fun/*",
        "https://*.jklm.fun/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data/words.txt",
        "page-bridge.js"
      ],
      "matches": [
        "https://jklm.fun/*",
        "https://*.jklm.fun/*"
      ]
    }
  ]
}
